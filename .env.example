# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Sendinblue (Brevo) — used to email resumes submitted via the career page
# Get your API key from https://app.brevo.com/settings/keys/api
SENDINBLUE_API_KEY=your-brevo-api-key-here

# The verified sender email address in your Brevo account
SENDINBLUE_SENDER_EMAIL=your-verified-sender@yourdomain.com
