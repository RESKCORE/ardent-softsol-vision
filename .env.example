# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# SMTP — used to send contact form submissions and resume uploads via email
# For testing: use a Gmail account with an App Password
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASS=your-16-char-app-password
# For production (Bluehost):
#   SMTP_HOST=mail.yourdomain.com
#   SMTP_PORT=465
#   SMTP_USER=you@yourdomain.com
#   SMTP_PASS=your-email-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: override the From address (defaults to SMTP_USER)
# SMTP_FROM="Your Name <you@yourdomain.com>"
